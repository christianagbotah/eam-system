  items       InventoryItem[]
  transfersFrom  InventoryTransfer[] @relation("InvTransferFrom")
  transfersTo    InventoryTransfer[] @relation("InvTransferTo")

  @@map("inventory_locations")
}

model InventoryAdjustment {
  id               String    @id @default(cuid())
  adjustmentNumber String    @unique                    // ADJ-YYYYMM-NNNN
  itemId           String
  type             String                                // gain, loss, correction
  quantity         Float
