// ============================================================================
// LOTO (Lock-Out/Tag-Out) Records
// ============================================================================
model LotoRecord {
  id                String    @id @default(cuid())
  lotoNumber        String    @unique                    // LOTO-YYYYMM-NNNN
  title             String
  description       String?
  assetId           String?
  departmentId      String?
  plantId           String?
  workOrderId       String?                                // linked WO if applicable

  // LOTO type and scope
  lotoType          String    @default("routine")           // routine, emergency, planned_maintenance, shutdown
  energySource      String                               // electrical, mechanical, hydraulic, pneumatic, thermal, chemical, other
  energySourceDesc   String?                              // specific description of the energy source

  // Requester info
  requestedById     String?
  requestDate       DateTime  @default(now())
  scheduledDate     DateTime?
  requiredFromDate   DateTime?
  requiredToDate     DateTime?

  // Approval workflow
  supervisorId      String?
  supervisorApprovedAt DateTime?
  safetyOfficerId   String?
  safetyOfficerApprovedAt DateTime?

  // Execution
  status            String    @default("pending")          // pending, approved, in_progress, completed, cancelled, expired
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelledReason    String?

  // LOTO details (JSON arrays)
  isolationPoints  String  @db.Text                    // JSON array of isolation point descriptions
  lockDevices       String  @db.Text                    // JSON array of lock device IDs/descriptions
  tagNumbers        String  @db.Text                    // JSON array of tag numbers
  verifiedBy        String?  @db.Text                   // JSON array of verifier names
  verificationDate   DateTime?

  // Workers affected
  affectedWorkers   String?  @db.Text                   // JSON array of worker names/IDs
  workerCount       Int?

  // Sign-off
  appliedBy         String?                              // who applied the lock
  removedBy         String?                              // who removed the lock
  removedAt         DateTime?

  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("loto_records")
}

// ============================================================================
// 23. ASSET EXTENDED
// ============================================================================

model BillOfMaterial {
  id                String    @id @default(cuid())
  parentId          String                               // → Asset (parent assembly)
  childAssetId      String                               // → Asset (component)
  partNumber        String?
  quantity          Float     @default(1)
  unit              String    @default("each")
  specification     String?
  status            String    @default("active")          // active, pending, obsolete, under_review
  revision          String?
  notes             String?
  createdAt         DateTime  @default(now())

  parent             Asset                @relation("BomParent", fields: [parentId], references: [id], onDelete: Cascade)
  childAsset         Asset                @relation("BomChild", fields: [childAssetId], references: [id], onDelete: Cascade)

  @@unique([parentId, childAssetId])
  @@map("bill_of_materials")
}

model DigitalTwin {
  id                String    @id @default(cuid())
  assetId           String    @unique
  name              String
  description       String?
  type              String    @default("other")            // pump, motor, compressor, valve, heat_exchanger, other
  parameters        String  @db.Text                    // JSON text of key parameters
  connections       String  @db.Text                    // JSON text of connections
  specification     String?  @db.Text                   // JSON text of specs
  healthScore       Int       @default(0)                   // 0-100
  syncInterval      String    @default("5min")             // real_time, 1min, 5min, 15min
  lastSynced        DateTime?
  isActive          Boolean   @default(true)
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  asset              Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy          User                @relation("DigitalTwinCreatedBy", fields: [createdById], references: [id])

  @@map("digital_twins")
}

// ============================================================================
// CHAT / MESSAGING
// ============================================================================

model Conversation {
  id        String    @id @default(cuid())
  name      String
  type      String    @default("direct")  // direct, group
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  participants ConversationParticipant[]
  messages     ChatMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  id         String    @id @default(cuid())
  userId     String
  convoId    String    @map("conversationId")
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  convo   Conversation  @relation(fields: [convoId], references: [id], onDelete: Cascade)

  @@unique([userId, convoId])
  @@map("conversation_participants")
}

// ============================================================================
// SESSION MANAGEMENT
// ============================================================================

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  roles     String   @db.Text  // JSON array of role slugs
  permissions String @db.Text // JSON array of permission slugs
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ChatMessage {
  id         String   @id @default(cuid())
  convoId    String   @map("conversationId")
  senderId   String
  content    String
  messageType String   @default("text")  // text, system
  createdAt  DateTime @default(now())

  convo   Conversation  @relation(fields: [convoId], references: [id], onDelete: Cascade)
  sender  User          @relation(fields: [senderId], references: [id])

  @@index([convoId, createdAt])
  @@map("chat_messages")
}

// ============================================================================
// REPAIRS MODULE — Work Order Management Extensions
// ============================================================================

model RepairMaterialRequest {
  id                    String    @id @default(cuid())
  workOrderId           String
  itemId                String?                              // → InventoryItem
  itemName              String
  quantityRequested     Float
  quantityApproved      Float     @default(0)
  quantityIssued        Float     @default(0)
  quantityReturned      Float     @default(0)
  unit                  String    @default("each")
  unitCost              Float?
  estimatedCost         Float     @default(0)
  urgency               String    @default("normal")          // low, normal, high, critical
  reason                String
  notes                 String?
  status                String    @default("pending")         // pending, supervisor_approved, storekeeper_approved, issued, partially_returned, fully_returned, rejected
  supervisorApprovedQuantity Float?                         // qty approved by supervisor (may differ from requested)
  storekeeperApprovedQuantity Float?                         // qty approved by storekeeper (may differ from supervisor qty)
  stockReserved         Boolean   @default(false)            // whether stock was reserved at storekeeper approval
  requestedById         String                               // → User
  supervisorApprovedById String?
  supervisorApprovedAt  DateTime?
  storekeeperApprovedById String?
  storekeeperApprovedAt DateTime?
  issuedById            String?                              // → User
  issuedAt              DateTime?
  returnedById          String?                              // → User
  returnedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // WorkOrder relation
  workOrder             WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  // InventoryItem relation
  item                  InventoryItem? @relation(fields: [itemId], references: [id])

  // User relations
  requestedBy           User       @relation("RepairMatReqRequested", fields: [requestedById], references: [id])
  supervisorApprovedBy  User?      @relation("RepairMatReqSupApproved", fields: [supervisorApprovedById], references: [id])
  storekeeperApprovedBy User?      @relation("RepairMatReqStoreApproved", fields: [storekeeperApprovedById], references: [id])
  issuedByUser          User?      @relation("RepairMatReqIssued", fields: [issuedById], references: [id])
  returnedByUser        User?      @relation("RepairMatReqReturned", fields: [returnedById], references: [id])

  @@map("repair_material_requests")
}

// 2. RepairToolRequest — Tool requests from technicians
model RepairToolRequest {
  id                    String    @id @default(cuid())
  workOrderId           String
  toolId                String?                              // → Tool
  toolName              String
  reason                String
  notes                 String?
  status                String    @default("pending")         // pending, supervisor_approved, storekeeper_approved, issued, returned, rejected
  urgency               String    @default("normal")          // low, normal, high, critical
  rejectionReason       String?
  toolConditionAtIssue  String?                              // new, good, fair, poor — captured at issue time
  toolConditionAtReturn String?                              // new, good, fair, poor — captured at return time
  requestedById         String                               // → User
  supervisorApprovedById String?
  supervisorApprovedAt  DateTime?
  storekeeperApprovedById String?
  storekeeperApprovedAt DateTime?
  issuedById            String?                              // → User
  issuedAt              DateTime?
  returnedById          String?                              // → User
  returnedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // WorkOrder relation
  workOrder             WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  // Tool relation
  tool                  Tool?     @relation(fields: [toolId], references: [id])

  // User relations
  requestedBy           User       @relation("RepairToolReqRequested", fields: [requestedById], references: [id])
  supervisorApprovedBy  User?      @relation("RepairToolReqSupApproved", fields: [supervisorApprovedById], references: [id])
  storekeeperApprovedBy User?      @relation("RepairToolReqStoreApproved", fields: [storekeeperApprovedById], references: [id])
  issuedByUser          User?      @relation("RepairToolReqIssued", fields: [issuedById], references: [id])
  returnedByUser        User?      @relation("RepairToolReqReturned", fields: [returnedById], references: [id])

  @@map("repair_tool_requests")
}

// 3. ToolTransferRequest — Tool transfer between technicians
model ToolTransferRequest {
  id                      String    @id @default(cuid())
  toolId                  String                               // → Tool
  fromUserId              String                               // → User
  toUserId                String                               // → User
  reason                  String
  notes                   String?
  status                  String    @default("pending")         // pending, storekeeper_approved, awaiting_handover, transferred, rejected
  rejectionReason         String?
  toolConditionAtTransfer String?                               // new, good, fair, poor — captured at approval
  fromUserAcceptedAt      DateTime?
  toUserAcceptedAt        DateTime?
  requestedById           String                               // → User
  storekeeperApprovedById  String?
  storekeeperApprovedAt   DateTime?
  transferredAt           DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Tool relation
  tool                    Tool      @relation(fields: [toolId], references: [id])

  // User relations
  fromUser                User      @relation("ToolTransferFrom", fields: [fromUserId], references: [id])
  toUser                  User      @relation("ToolTransferTo", fields: [toUserId], references: [id])
  requestedBy             User      @relation("ToolTransferRequested", fields: [requestedById], references: [id])
  storekeeperApprovedBy   User?     @relation("ToolTransferStoreApproved", fields: [storekeeperApprovedById], references: [id])

  @@map("tool_transfer_requests")
}

// 4. WorkOrderDowntime — Equipment downtime related to WOs
model WorkOrderDowntime {
  id                String    @id @default(cuid())
  workOrderId       String
  assetId           String?                              // → Asset
  assetName         String
  downtimeStart     DateTime
  downtimeEnd       DateTime?
  durationMinutes   Float     @default(0)
  reason            String
  category          String    @default("unplanned")       // planned, unplanned, partial
  impactLevel       String    @default("medium")         // low, medium, high, critical
  productionLoss    Float?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // WorkOrder relation
  workOrder         WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("wo_downtimes")
}

// 5. RepairCompletion — Completion record capturing all closure data
model RepairCompletion {
  id                     String    @id @default(cuid())
  workOrderId            String    @unique
  completionNotes        String?
  findings               String?
  rootCause              String?
  correctiveAction       String?
  materialsUsedSummary   String    @default("[]")  @db.Text // JSON: [{itemId, name, qty, cost}]
  toolsUsedSummary       String    @default("[]")  @db.Text // JSON: [{toolId, name}]
  totalLaborHours        Float     @default(0)
  totalMaterialCost      Float     @default(0)
  totalToolCost          Float     @default(0)
  totalDowntimeMinutes   Float     @default(0)
  supervisorReviewNotes  String?
  supervisorApprovedById String?                              // → User
  supervisorApprovedAt   DateTime?
  supervisorStatus       String    @default("pending_review") // pending_review, approved, rework_requested
  reworkReason           String?
  reworkCount            Int       @default(0)
  plannerClosedById      String?                              // → User
  plannerClosedAt        DateTime?
  plannerStatus          String    @default("pending_closure") // pending_closure, closed
  closureNotes           String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // WorkOrder relation
  workOrder              WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  // User relations
  supervisorApprovedBy   User?     @relation("RepairCompSupApproved", fields: [supervisorApprovedById], references: [id])
  plannerClosedBy        User?     @relation("RepairCompPlannerClosed", fields: [plannerClosedById], references: [id])

  @@map("repair_completions")
}

// ============================================================================
// FILE ATTACHMENTS
// ============================================================================

model Attachment {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String   // MIME type
  fileSize    Int      // bytes
  filePath    String   // relative path on disk
  entityType  String   // e.g. 'work_order', 'maintenance_request', 'asset', 'safety_incident'
  entityId    String
  uploadedById String
  uploadedAt  DateTime @default(now())
  description String?

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([entityType, entityId])
  @@map("attachments")
}
