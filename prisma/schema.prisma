generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. CORE RBAC SYSTEM
// ============================================================================

model Role {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  level       Int      @default(0)       // hierarchy level (higher = more privileges)
  isSystem    Boolean  @default(false)   // cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique          // e.g. "work_orders.view"
  name        String                     // e.g. "View Work Orders"
  module      String                     // e.g. "work_orders"
  action      String                     // view, create, update, delete, approve, assign, execute, export
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String
  fullName     String
  staffId      String?   @unique
  phone        String?
  avatar       String?
  department   String?
  status       String    @default("active")  // active, inactive
  isVendorAdmin Boolean  @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // RBAC relations
  userRoles       UserRole[]
  directPerms     UserPermission[]
  plantAccess     UserPlant[]

  // Department supervision
  deptSupervised  Department[]  @relation("DeptSupervisor")

  // Maintenance Request relations
  mrRequested     MaintenanceRequest[] @relation("MRRequester")
  mrSupervised    MaintenanceRequest[] @relation("MRSupervisor")
  mrApproved      MaintenanceRequest[] @relation("MRApprover")
  mrPlanned       MaintenanceRequest[] @relation("MRPlanner")

  // Work Order relations
  woAssigned      WorkOrder[]          @relation("WOAssignedTo")
  woTeamLeader    WorkOrder[]          @relation("WOTeamLeader")
  woSupervised    WorkOrder[]          @relation("WOSupervisor")
  woAssignedBy    WorkOrder[]          @relation("WOAssignedBy")
  woPlanned       WorkOrder[]          @relation("WOPlanner")
  woLocked        WorkOrder[]          @relation("WOLocker")

  // Work Order sub-table relations
  woTeamMembers   WorkOrderTeamMember[]
  woTimeLogs      WorkOrderTimeLog[]
  woComments      WorkOrderComment[]
  woMaterialsRequested WorkOrderMaterial[] @relation("WOMatRequested")
  woMaterialsApproved  WorkOrderMaterial[] @relation("WOMatApproved")
  woMaterialsIssued    WorkOrderMaterial[] @relation("WOMatIssued")

  // Audit
  auditLogs       AuditLog[]
  notifications   Notification[]

  // Asset Management relations
  assetsCreated        Asset[]                   @relation("AssetCreatedBy")
  assetsAssigned       Asset[]                   @relation("AssetAssignedTo")
  inventoryItemsCreated InventoryItem[]          @relation("InventoryItemCreatedBy")
  stockMovements       StockMovement[]
  pmSchedulesAssigned  PmSchedule[]              @relation("PmScheduleAssignedTo")
  pmSchedulesCreated   PmSchedule[]              @relation("PmScheduleCreatedBy")
  woStatusHistory      WorkOrderStatusHistory[]
  mrComments           MaintenanceRequestComment[]

  @@map("users")
}

model UserRole {
  id     String   @id @default(cuid())
  userId String
  roleId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserPermission {
  id           String    @id @default(cuid())
  userId       String
  permissionId String
  isGranted    Boolean   @default(true)
  expiresAt    DateTime?
  grantedBy    String?   // userId of the granter
  createdAt    DateTime  @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ============================================================================
// 2. MODULE SUBSCRIPTION SYSTEM (3-tier)
// ============================================================================

model SystemModule {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  description     String?
  version         String    @default("1.0.0")
  isCore          Boolean   @default(false)
  isSystemLicensed Boolean  @default(false) // vendor-level license flag
  licenseKey      String?
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  companyModules CompanyModule[]

  @@map("system_modules")
}

model CompanyModule {
  id              String    @id @default(cuid())
  systemModuleId  String
  companyId       String?   // tenant/company reference (optional for single-company setup)
  isActive        Boolean   @default(false)  // licensed by vendor
  isEnabled       Boolean   @default(false)  // activated by company
  licensedAt      DateTime?
  licensedBy      String?
  activatedAt     DateTime?
  activatedBy     String?
  activationLocked Boolean  @default(false)  // prevent deactivation once locked
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  systemModule SystemModule @relation(fields: [systemModuleId], references: [id], onDelete: Cascade)

  @@unique([systemModuleId, companyId])
  @@map("company_modules")
}

// ============================================================================
// 3. PLANT / ORGANIZATION
// ============================================================================

model Plant {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  location  String?
  country   String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments   Department[]
  plantAccess   UserPlant[]
  assets        Asset[]
  inventoryItems InventoryItem[]

  @@map("plants")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String
  plantId     String
  parentId    String?              // self-reference for sub-departments
  supervisorId String?             // → User
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plant      Plant       @relation(fields: [plantId], references: [id], onDelete: Cascade)
  parent     Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children   Department[] @relation("DeptHierarchy")
  supervisor User?       @relation("DeptSupervisor", fields: [supervisorId], references: [id])
  assets       Asset[]
  pmSchedules  PmSchedule[]

  @@map("departments")
}

model UserPlant {
  id          String   @id @default(cuid())
  userId      String
  plantId     String
  accessLevel String   @default("read")  // read, write, admin
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([userId, plantId])
  @@map("user_plants")
}

// ============================================================================
// 4. MAINTENANCE REQUESTS
// ============================================================================

model MaintenanceRequest {
  id                String    @id @default(cuid())
  requestNumber     String    @unique           // format MR-YYYYMM-NNNN
  title             String
  description       String?
  priority          String    @default("medium") // low, medium, high, urgent
  category          String?                      // mechanical, electrical, hydraulic, etc.
  status            String    @default("pending") // pending, in_progress, approved, rejected, converted
  workflowStatus    String    @default("pending") // pending, supervisor_review, approved, rejected, assigned_to_planner, work_order_created, technician_completed, planner_confirmed, satisfactory, supervisor_rejected, closed
  machineDownStatus Boolean?  @default(false)
  assetId           String?
  departmentId      String?
  requestedBy       String                      // → User
  supervisorId      String?                     // → User
  approvedBy        String?                     // → User
  assignedPlannerId String?                     // → User
  workOrderId       String?   @unique           // → WorkOrder
  plantId           String?
  plannedStart      DateTime?
  plannedEnd        DateTime?
  estimatedHours    Float?
  slaHours          Float?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // User relations
  requester     User?       @relation("MRRequester", fields: [requestedBy], references: [id])
  supervisor    User?       @relation("MRSupervisor", fields: [supervisorId], references: [id])
  approver      User?       @relation("MRApprover", fields: [approvedBy], references: [id])
  assignedPlanner User?     @relation("MRPlanner", fields: [assignedPlannerId], references: [id])

  // Work Order relation
  workOrder     WorkOrder?

  // Comments
  comments      MaintenanceRequestComment[]

  @@map("maintenance_requests")
}

// ============================================================================
// 5. WORK ORDERS
// ============================================================================

model WorkOrder {
  id                  String    @id @default(cuid())
  woNumber            String    @unique           // format WO-YYYYMM-NNNN
  title               String
  description         String?
  type                String    @default("corrective") // preventive, corrective, predictive, inspection, project, emergency
  priority            String    @default("medium")     // low, medium, high, critical
  status              String    @default("draft")       // draft, requested, approved, planned, assigned, in_progress, waiting_parts, on_hold, completed, closed, cancelled
  maintenanceRequestId String?  @unique
  assetId             String?
  assetName           String?
  departmentId        String?
  assignedTo          String?                       // → User
  teamLeaderId        String?                       // → User
  assignedSupervisorId String?                      // → User
  assignedBy          String?                       // → User
  assignmentType      String?                       // direct, via_supervisor
  plannerId           String?                       // → User
  estimatedHours      Float?
  actualHours         Float?
  plannedStart        DateTime?
  plannedEnd          DateTime?
  actualStart         DateTime?
  actualEnd           DateTime?
  totalCost           Float     @default(0)
  laborCost           Float     @default(0)
  partsCost           Float     @default(0)
  contractorCost      Float     @default(0)
  failureDescription  String?
  causeDescription    String?
  actionDescription   String?
  plantId             String?
  notes               String?
  isLocked            Boolean   @default(false)
  lockedBy            String?                        // → User
  lockedAt            DateTime?
  lockReason          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Maintenance Request relation
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])

  // User relations
  assignee           User?  @relation("WOAssignedTo", fields: [assignedTo], references: [id])
  teamLeader         User?  @relation("WOTeamLeader", fields: [teamLeaderId], references: [id])
  assignedSupervisor User?  @relation("WOSupervisor", fields: [assignedSupervisorId], references: [id])
  assigner           User?  @relation("WOAssignedBy", fields: [assignedBy], references: [id])
  planner            User?  @relation("WOPlanner", fields: [plannerId], references: [id])
  locker             User?  @relation("WOLocker", fields: [lockedBy], references: [id])

  // Sub-table relations
  teamMembers        WorkOrderTeamMember[]
  timeLogs           WorkOrderTimeLog[]
  materials          WorkOrderMaterial[]
  comments           WorkOrderComment[]

  // Status History relations
  statusHistory      WorkOrderStatusHistory[]

  @@map("work_orders")
}

model WorkOrderTeamMember {
  id          String   @id @default(cuid())
  workOrderId String
  userId      String
  role        String   @default("assistant")  // team_leader, assistant, specialist
  assignedAt  DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wo_team_members")
}

model WorkOrderTimeLog {
  id          String   @id @default(cuid())
  workOrderId String
  userId      String
  action      String                         // start, pause, resume, complete
  notes       String?
  timestamp   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wo_time_logs")
}

model WorkOrderMaterial {
  id          String   @id @default(cuid())
  workOrderId String
  itemId      String?
  itemName    String?
  quantity    Float?
  unitCost    Float?
  totalCost   Float?
  status      String   @default("requested")  // requested, approved, issued, returned
  requestedBy String?                         // → User
  approvedBy  String?                         // → User
  issuedBy    String?                         // → User
  createdAt   DateTime @default(now())

  workOrder          WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  requester          User?     @relation("WOMatRequested", fields: [requestedBy], references: [id])
  approver           User?     @relation("WOMatApproved", fields: [approvedBy], references: [id])
  issuer             User?     @relation("WOMatIssued", fields: [issuedBy], references: [id])

  @@map("wo_materials")
}

model WorkOrderComment {
  id          String   @id @default(cuid())
  workOrderId String
  userId      String
  content     String
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wo_comments")
}

// ============================================================================
// 6. STATUS TRANSITIONS (DB-driven state machine)
// ============================================================================

model StatusTransition {
  id               String   @id @default(cuid())
  entityType       String                       // maintenance_request, work_order
  fromStatus       String?                      // null = initial state
  toStatus         String
  allowedRoleSlugs String                       // JSON string array, e.g. ["supervisor","admin"]
  requiresApproval Boolean  @default(false)
  requiresReason   Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  @@map("status_transitions")
}

// ============================================================================
// 7. AUDIT LOG
// ============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String                       // create, update, delete, view
  entityType String?
  entityId   String?
  oldValues  String?                      // JSON string of previous field values
  newValues  String?                      // JSON string of new field values
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ============================================================================
// 8. COMPANY PROFILE
// ============================================================================

model CompanyProfile {
  id          String   @id @default(cuid())
  companyName String                           // legal name of the company
  tradingName String?                          // display/brand name
  logo        String?                          // URL or path to company logo
  address     String?
  city        String?
  region      String?
  country     String?
  postalCode  String?
  phone       String?
  email       String?
  website     String?
  industry    String?                          // manufacturing, mining, food, etc.
  employeeCount String?                        // e.g. "100-500"
  fiscalYearStart String?                      // e.g. "January"
  timezone    String   @default("UTC")
  currency    String   @default("GHS")         // default currency code
  dateFormat  String   @default("DD/MM/YYYY")
  isSetupComplete Boolean @default(false)      // has completed initial setup wizard
  setupCompletedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_profile")
}

// ============================================================================
// 9. NOTIFICATIONS
// ============================================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String                       // recipient
  type        String                       // mr_assigned, mr_approved, mr_rejected, wo_assigned, wo_started, wo_completed, wo_closed, system, info
  title       String
  message     String
  entityType  String?                      // maintenance_request, work_order
  entityId    String?                      // reference to the entity
  actionUrl   String?                      // SPA page to navigate to, e.g. "mr-detail"
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================================================
// 10. ASSET MANAGEMENT
// ============================================================================

model AssetCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   AssetCategory?  @relation("AssetCategoryHierarchy", fields: [parentId], references: [id])
  children AssetCategory[] @relation("AssetCategoryHierarchy")
  assets   Asset[]

  @@map("asset_categories")
}

model Asset {
  id                String    @id @default(cuid())
  name              String
  assetTag          String    @unique
  description       String?
  categoryId        String
  serialNumber      String?   @unique
  manufacturer      String?
  model             String?
  yearManufactured  Int?
  condition         String    @default("new")           // new, good, fair, poor, out_of_service
  status            String    @default("operational")   // operational, standby, under_maintenance, decommissioned, disposed
  criticality       String    @default("medium")        // low, medium, high, critical
  location          String?
  building          String?
  floor             String?
  area              String?
  plantId           String
  departmentId      String?
  purchaseDate      DateTime?
  purchaseCost      Float?
  warrantyExpiry    DateTime?
  installedDate     DateTime?
  expectedLifeYears Int?
  currentValue      Float?
  depreciationRate  Float?
  imageUrl          String?
  drawingsUrl       String?
  manualUrl         String?
  specification     String                            // JSON text for flexible specs
  parentId          String?
  isActive          Boolean   @default(true)
  createdById       String
  assignedToId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  category           AssetCategory       @relation(fields: [categoryId], references: [id])
  parent             Asset?              @relation("AssetHierarchy", fields: [parentId], references: [id])
  children           Asset[]             @relation("AssetHierarchy")
  plant              Plant               @relation(fields: [plantId], references: [id])
  department         Department?         @relation(fields: [departmentId], references: [id])
  createdBy          User                @relation("AssetCreatedBy", fields: [createdById], references: [id])
  assignedTo         User?               @relation("AssetAssignedTo", fields: [assignedToId], references: [id])
  pmSchedules        PmSchedule[]

  @@map("assets")
}

// ============================================================================
// 11. INVENTORY MANAGEMENT
// ============================================================================

model InventoryItem {
  id                String   @id @default(cuid())
  itemCode          String   @unique
  name              String
  description       String?
  category          String   @default("other")       // spare_part, consumable, tool, material, other
  unitOfMeasure     String   @default("each")        // each, kg, liter, meter, set, box, roll
  currentStock      Float    @default(0)
  minStockLevel     Float    @default(0)
  maxStockLevel     Float?
  reorderQuantity   Float?
  unitCost          Float?
  supplier          String?
  supplierPartNumber String?
  location          String?
  binLocation       String?
  shelfLocation     String?
  plantId           String
  isActive          Boolean  @default(true)
  specification     String                            // JSON text
  imageUrls         String                            // JSON text array
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  plant           Plant           @relation(fields: [plantId], references: [id])
  createdBy       User            @relation("InventoryItemCreatedBy", fields: [createdById], references: [id])
  stockMovements  StockMovement[]

  @@map("inventory_items")
}

model StockMovement {
  id            String   @id @default(cuid())
  itemId        String
  type          String                                // in, out, adjustment, transfer
  quantity      Float
  previousStock Float
  newStock      Float
  reason        String?
  referenceType String?                               // work_order, requisition, return, audit
  referenceId   String?
  performedById String
  notes         String?
  createdAt     DateTime @default(now())

  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  performedBy  User          @relation(fields: [performedById], references: [id])

  @@map("stock_movements")
}

// ============================================================================
// 12. PREVENTIVE MAINTENANCE
// ============================================================================

model PmSchedule {
  id                String    @id @default(cuid())
  title             String
  description       String?
  assetId           String
  frequencyType     String                           // daily, weekly, biweekly, monthly, quarterly, semiannual, annual, custom_hours, custom_days, meter_based
  frequencyValue    Int
  lastCompletedDate DateTime?
  nextDueDate       DateTime?
  estimatedDuration Float                            // hours
  priority          String    @default("medium")     // low, medium, high, critical
  assignedToId      String?
  departmentId      String?
  isActive          Boolean   @default(true)
  autoGenerateWO    Boolean   @default(true)
  leadDays          Int       @default(3)
  woTypeId          String?
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  asset       Asset       @relation(fields: [assetId], references: [id])
  assignedTo  User?       @relation("PmScheduleAssignedTo", fields: [assignedToId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  createdBy   User        @relation("PmScheduleCreatedBy", fields: [createdById], references: [id])

  @@map("pm_schedules")
}

// ============================================================================
// 13. WORK ORDER STATUS HISTORY
// ============================================================================

model WorkOrderStatusHistory {
  id            String   @id @default(cuid())
  workOrderId   String
  fromStatus    String?
  toStatus      String
  performedById String
  notes         String?
  createdAt     DateTime @default(now())

  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  performedBy  User      @relation(fields: [performedById], references: [id])

  @@map("wo_status_history")
}

// ============================================================================
// 14. MAINTENANCE REQUEST COMMENTS
// ============================================================================

model MaintenanceRequestComment {
  id                    String   @id @default(cuid())
  maintenanceRequestId  String
  userId                String
  content               String
  createdAt             DateTime @default(now())

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mr_comments")
}


