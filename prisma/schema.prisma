generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  password      String
  fullName      String
  avatar        String?
  phone         String?
  departmentId  String?
  supervisorId  String?
  plantId       String?
  status        String    @default("active") // active, inactive, suspended
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  department    Department?      @relation(fields: [departmentId], references: [id])
  supervisor    User?            @relation("SupervisorOf", fields: [supervisorId], references: [id])
  subordinates  User[]           @relation("SupervisorOf")
  plant         Plant?           @relation(fields: [plantId], references: [id])
  userRoles     UserRole[]
  directPerms   UserPermission[]
  plantAccess   UserPlant[]
  auditLogs     AuditLog[]
  requestsCreated   MaintenanceRequest[] @relation("Requester")
  requestsReviewed  MaintenanceRequest[] @relation("Reviewer")
  woCreated         WorkOrder[] @relation("WOCreator")

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  level       Int      @default(0) // higher = more privileges
  isSystem    Boolean  @default(false) // cannot be deleted
  color       String?  // UI theme color
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles      UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "work_orders.view"
  name        String   // e.g. "View Work Orders"
  module      String   // e.g. "work_orders"
  action      String   // view, create, update, delete, approve, assign, execute, export
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model UserRole {
  id     String   @id @default(cuid())
  userId String
  roleId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String    @id @default(cuid())
  userId       String
  permissionId String
  isGranted    Boolean   @default(true)
  grantedBy    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ============================================================================
// MODULE & SUBSCRIPTION
// ============================================================================

model Module {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  icon          String?  // lucide icon name
  version       String   @default("1.0.0")
  isCore        Boolean  @default(false)
  isActive      Boolean  @default(false) // vendor licensed
  sortOrder     Int      @default(0)
  routePath     String?  // frontend route
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyModules CompanyModule[]

  @@map("modules")
}

model CompanyModule {
  id          String    @id @default(cuid())
  moduleId    String
  isEnabled   Boolean   @default(false) // company activated
  activatedAt DateTime?
  activatedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId])
  @@map("company_modules")
}

// ============================================================================
// ORGANIZATION
// ============================================================================

model Plant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  plantAccess UserPlant[]

  @@map("plants")
}

model UserPlant {
  id          String  @id @default(cuid())
  userId      String
  plantId     String
  isPrimary   Boolean @default(false)
  accessLevel String @default("read") // read, write, admin
  createdAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([userId, plantId])
  @@map("user_plants")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  parentId    String?
  level       Int      @default(1) // 1=Main, 2=Sub
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    Department?      @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[]     @relation("DeptHierarchy")
  users     User[]

  @@map("departments")
}

// ============================================================================
// AUDIT
// ============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // login, logout, create, update, delete
  entityType String?
  entityId   String?
  details    String?  // JSON string
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ============================================================================
// MAINTENANCE REQUESTS
// ============================================================================

model MaintenanceRequest {
  id              String   @id @default(cuid())
  requestNumber   String   @unique
  title           String
  description     String?
  priority        String   @default("medium") // low, medium, high, urgent
  machineDown     Boolean  @default(false)
  assetId         String?
  assetName       String?
  location        String?
  status          String   @default("pending") // pending, approved, rejected, converted
  workflowStatus  String   @default("pending") // pending, supervisor_review, approved, assigned_to_planner, work_order_created, in_progress, technician_completed, planner_confirmed, satisfactory, closed
  category        String?  // mechanical, electrical, hydraulic, etc.
  requestedById   String
  supervisorId    String?
  approvedById    String?
  approvedAt      DateTime?
  reviewNotes     String?
  plannerId       String?
  workOrderId     String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester   User?              @relation("Requester", fields: [requestedById], references: [id])
  reviewer    User?              @relation("Reviewer", fields: [approvedById], references: [id])
  workOrder   WorkOrder?         @relation(fields: [workOrderId], references: [id])
  comments    MRComment[]
  statusHistory MRStatusHistory[]

  @@map("maintenance_requests")
}

model MRComment {
  id                 String   @id @default(cuid())
  maintenanceRequestId String
  userId             String
  content            String
  createdAt          DateTime @default(now())

  request MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)

  @@map("mr_comments")
}

model MRStatusHistory {
  id                 String   @id @default(cuid())
  maintenanceRequestId String
  fromStatus         String?
  toStatus           String
  changedById        String?
  reason             String?
  createdAt          DateTime @default(now())

  request MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)

  @@map("mr_status_history")
}

// ============================================================================
// WORK ORDERS
// ============================================================================

model WorkOrder {
  id              String    @id @default(cuid())
  woNumber        String    @unique
  title           String
  description     String?
  type            String    @default("corrective") // preventive, corrective, predictive, inspection, emergency, project
  priority        String    @default("medium") // low, medium, high, critical, emergency
  status          String    @default("draft") // draft, requested, approved, planned, assigned, in_progress, waiting_parts, on_hold, completed, verified, closed, cancelled
  assetId         String?
  assetName       String?
  departmentId    String?
  requestId       String?

  // Assignment
  assignedToId    String?
  assignedToName  String?
  teamLeaderId    String?
  supervisorId    String?
  plannerId       String?
  assignedById    String?
  assignedAt      DateTime?
  assignmentType  String?   // direct, via_supervisor

  // Planning
  estimatedHours  Float?
  plannedStart    DateTime?
  plannedEnd      DateTime?

  // Execution
  actualStart     DateTime?
  actualEnd       DateTime?
  actualHours     Float?

  // Cost
  totalCost       Float     @default(0)
  materialCost    Float     @default(0)
  laborCost       Float     @default(0)

  // SLA
  slaHours        Float?
  slaStartedAt    DateTime?
  slaBreached     Boolean   @default(false)
  responseDue     DateTime?
  resolutionDue   DateTime?

  // Failure Analysis
  failureDescription String?
  causeDescription   String?
  actionDescription  String?

  // Lock
  isLocked        Boolean   @default(false)
  lockedBy        String?
  lockedAt        DateTime?
  lockReason      String?

  // Meta
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  request      MaintenanceRequest?
  creator      User?               @relation("WOCreator", fields: [createdById], references: [id])
  teamMembers  WOTeamMember[]
  timeLogs     WOTimeLog[]
  materials    WOMaterial[]
  comments     WOComment[]
  statusHistory WOStatusHistory[]

  @@map("work_orders")
}

model WOTeamMember {
  id          String  @id @default(cuid())
  workOrderId String
  userId      String?
  userName    String?
  role        String  @default("member") // leader, member, assistant, specialist
  hours       Float?
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("wo_team_members")
}

model WOTimeLog {
  id          String    @id @default(cuid())
  workOrderId String
  userId      String?
  userName    String?
  action      String    // start, pause, resume, complete
  startTime   DateTime?
  endTime     DateTime?
  duration    Float?
  note        String?
  createdAt   DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("wo_time_logs")
}

model WOMaterial {
  id          String  @id @default(cuid())
  workOrderId String
  itemName    String?
  quantity    Float?
  unit        String?
  unitCost    Float?
  totalCost   Float?
  status      String  @default("requested") // requested, approved, issued, returned
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("wo_materials")
}

model WOComment {
  id          String   @id @default(cuid())
  workOrderId String
  userId      String?
  userName    String?
  content     String
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("wo_comments")
}

model WOStatusHistory {
  id          String   @id @default(cuid())
  workOrderId String
  fromStatus  String?
  toStatus    String
  changedById String?
  changedByName String?
  reason      String?
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("wo_status_history")
}
