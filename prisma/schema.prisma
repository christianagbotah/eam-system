  name        String
  code        String    @unique
  type        String    @default("warehouse")   // warehouse, storeroom, tool_crib, site, staging, production, picking, receiving
  address     String?
  isActive    Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
