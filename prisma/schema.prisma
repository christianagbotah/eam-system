model ShiftHandover {
  id                String    @id @default(cuid())
  shiftDate         DateTime
  shiftType         String                               // morning, afternoon, night
  fromShift         String?
  toShift           String?
  departmentId      String?
  handedOverById    String
  receivedById      String?
  status            String    @default("pending")         // pending, confirmed
  tasksSummary      String  @db.Text                    // JSON text
  pendingIssues     String  @db.Text                    // JSON text
