  capaNumber        String    @unique
  title             String
  description       String
  type              String                               // corrective, preventive
  source            String                               // ncr, audit, inspection, customer_complaint
  sourceId          String?
  severity          String    @default("medium")
  status            String    @default("open")            // open, in_progress, implemented, verified, closed
  rootCause         String?
  correctiveAction  String  @db.Text                    // JSON text
  preventiveAction  String?  @db.Text                 // JSON text
  responsibleId     String?
  dueDate           DateTime?
  verifiedById      String?
  verifiedAt        DateTime?
  effectiveness     String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("corrective_actions")
}

model SpcProcess {
  id          String   @id @default(cuid())
  processName String
  parameter   String
  unit        String   @default("")
  specMin     Float?
  specMax     Float?
  target      Float?
  status      String   @default("active")  // active, inactive
  samples     String   @db.Text  // JSON array of sample values
  createdById String
  createdBy   User     @relation("SpcProcessCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

