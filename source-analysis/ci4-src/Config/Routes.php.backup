        $routes->get('surveys/(:num)', 'SurveysController::show/$1');
        $routes->post('surveys', 'SurveysController::create');
    });
    
    // ========================================================================
    // MRMP MODULE - PM, Calibration, IoT, Predictive
    // ========================================================================
    $routes->group('', ['namespace' => 'App\Controllers\Api\V1\Modules\MRMP'], function($routes) {
        // PM Templates
        $routes->get('pm-templates', 'PmController::index');
        $routes->get('pm-templates/(:num)', 'PmController::show/$1');
