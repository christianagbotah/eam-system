        $routes->put('meters/(:num)', 'MetersController::update/$1');
        $routes->delete('meters/(:num)', 'MetersController::delete/$1');
        $routes->post('meters/(:num)/readings', 'MetersController::recordReading/$1');
        $routes->get('meters/(:num)/readings', 'MetersController::readings/$1');
        
        // IoT
        $routes->get('iot/devices', 'IoTController::index');
        $routes->get('iot/devices/(:num)', 'IoTController::show/$1');
        $routes->post('iot/devices', 'IoTController::create');
        $routes->put('iot/devices/(:num)', 'IoTController::update/$1');
        $routes->delete('iot/devices/(:num)', 'IoTController::delete/$1');
