        $routes->post('maintenance/work-orders/(:num)/time-logs/stop', 'WorkOrderCompletionController::stopTimeLog/$1');
        $routes->get('maintenance/work-orders/(:num)/materials-used', 'WorkOrderCompletionController::getMaterialsUsed/$1');
        $routes->post('maintenance/work-orders/(:num)/materials-used', 'WorkOrderCompletionController::addMaterialUsed/$1');
        
        // Maintenance Orders
        $routes->get('maintenance-orders', 'MaintenanceOrderController::index');
        $routes->get('maintenance-orders/dashboard', 'MaintenanceOrderController::dashboard');
        $routes->get('maintenance-orders/export', 'MaintenanceOrderController::export');
        
        // Work Order Team
        $routes->get('work-orders/(:num)/team', 'WorkOrderTeamController::getTeamMembers/$1');
        $routes->post('work-orders/(:num)/team', 'WorkOrderTeamController::addTeamMember/$1');
        $routes->delete('work-orders/(:num)/team/(:num)', 'WorkOrderTeamController::removeTeamMember/$1/$2');
        
        // Completion Analytics
        $routes->get('analytics/completion', 'CompletionAnalyticsController::index');
        $routes->get('analytics/work-order-performance', 'WorkOrderAnalyticsController::performance');
    });
    
    // ========================================================================
    // TRAC MODULE - Risk, LOTO, Permits, Tools
    // ========================================================================
    $routes->group('', ['namespace' => 'App\Controllers\Api\V1\Modules\TRAC'], function($routes) {
        // Risk Assessment
        $routes->get('risk-assessment', 'RiskAssessmentController::index');
        $routes->get('risk-assessment/(:num)', 'RiskAssessmentController::show/$1');
        $routes->post('risk-assessment', 'RiskAssessmentController::create');
        $routes->put('risk-assessment/(:num)', 'RiskAssessmentController::update/$1');
        $routes->delete('risk-assessment/(:num)', 'RiskAssessmentController::delete/$1');
        $routes->post('risk-assessment/(:num)/approve', 'RiskAssessmentController::approve/$1');
        $routes->post('risk-assessment/(:num)/measure', 'RiskAssessmentController::addMeasure/$1');
        
        // LOTO
        $routes->get('loto', 'LOTOController::index');
        $routes->get('loto-procedures', 'LOTOController::index');
        $routes->get('loto/active', 'LOTOController::getActive');
        $routes->get('loto-locks', 'LOTOLockController::index');
        $routes->get('loto/(:num)', 'LOTOController::show/$1');
        $routes->post('loto', 'LOTOController::create');
        $routes->post('loto-procedures', 'LOTOController::create');
        $routes->post('loto/apply', 'LOTOController::apply');
        $routes->put('loto/(:num)', 'LOTOController::update/$1');
        $routes->delete('loto/(:num)', 'LOTOController::delete/$1');
        $routes->post('loto/(:num)/verify', 'LOTOController::verify/$1');
        $routes->post('loto/(:num)/remove', 'LOTOController::remove/$1');
        
        // Permits
        $routes->get('permits', 'PermitToWorkController::index');
        $routes->get('permits-to-work', 'PermitToWorkController::index');
        $routes->get('permits/(:num)', 'PermitToWorkController::show/$1');
        $routes->post('permits', 'PermitToWorkController::create');
        $routes->post('permits-to-work', 'PermitToWorkController::create');
        $routes->put('permits/(:num)', 'PermitToWorkController::update/$1');
        $routes->delete('permits/(:num)', 'PermitToWorkController::delete/$1');
        $routes->post('permits-to-work/(:num)/approve', 'PermitToWorkController::approve/$1');
        
        // Tools
        $routes->get('tools', 'ToolsController::index');
        $routes->get('tools/(:num)', 'ToolsController::show/$1');
        $routes->post('tools', 'ToolsController::create');
        $routes->put('tools/(:num)', 'ToolsController::update/$1');
        $routes->delete('tools/(:num)', 'ToolsController::delete/$1');
    });
    
    // ========================================================================
    // LICENSE MODULE - Module Licensing & Activation
    // ========================================================================
    $routes->group('licenses', ['namespace' => 'App\Controllers\Api\V1\Modules\LICENSE'], function($routes) {
        $routes->get('system-modules', 'ModuleLicenseController::getSystemModules');
        $routes->post('system-modules/(:segment)/enable', 'ModuleLicenseController::enableSystemModule/$1');
        $routes->post('system-modules/(:segment)/disable', 'ModuleLicenseController::disableSystemModule/$1');
        $routes->get('company-modules', 'ModuleLicenseController::getCompanyModules');
        $routes->post('company-modules/(:segment)/activate', 'ModuleLicenseController::activateCompanyModule/$1');
        $routes->post('company-modules/(:segment)/deactivate', 'ModuleLicenseController::deactivateCompanyModule/$1');
        $routes->get('check/(:segment)', 'ModuleLicenseController::checkModuleAccess/$1');
        $routes->get('usage-logs', 'ModuleLicenseController::getUsageLogs');
    });
});

