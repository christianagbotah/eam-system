<?php

use CodeIgniter\Router\RouteCollection;

/**
 * @var RouteCollection $routes
 * 
 * Ghana Industrial EAM System - Professional Route Configuration
 * Architecture: Modular + Unified API Gateway Pattern
 */

// ============================================================================
// CORE: Load Modular Routes
// ============================================================================
require_once APPPATH . 'Config/Routes/AllModules.php';

// ============================================================================
// API GATEWAY: Unified /api/v1/eam/* Endpoint
// All frontend requests route through this unified gateway
// Backend controllers are organized by modules for maintainability
// ============================================================================

$routes->group('api/v1/eam', function($routes) {
    
    // ========================================================================
    // CORE MODULE - Authentication, Dashboard, System
    // ========================================================================
    $routes->group('', ['namespace' => 'App\Controllers\Api\V1\Modules\Core'], function($routes) {
        // Auth
        $routes->post('auth/login', 'AuthController::login');
        $routes->post('auth/logout', 'AuthController::logout');
        $routes->post('auth/refresh', 'AuthController::refresh');
        $routes->post('auth/forgot-password', 'PasswordResetController::requestReset');
        $routes->post('auth/reset-password', 'PasswordResetController::resetPassword');
        
        // Dashboard
        $routes->get('dashboard/stats', 'DashboardController::stats');
        $routes->get('dashboard/admin', 'DashboardController::admin');
        $routes->get('dashboard/supervisor', 'DashboardController::supervisor');
        $routes->get('dashboard/technician', 'DashboardController::technician');
        $routes->get('dashboard/operator', 'DashboardController::operator');
        $routes->get('dashboard/planner', 'DashboardController::planner');
        
        // Plant Test (Debug)
        $routes->get('plants/test-filter', 'PlantTestController::testPlantFilter');
        
        // System
        $routes->get('health', 'HealthController::index');
        $routes->get('settings/system', 'SystemSettingsController::index');
        $routes->put('settings/system', 'SystemSettingsController::update');
        $routes->get('settings/theme', 'SystemSettingsController::theme');
        $routes->get('digital-twin/metrics', 'DigitalTwinController::metrics');
        
        // Notifications
        $routes->get('notifications', 'NotificationsController::index');
        $routes->put('notifications/(:num)/read', 'NotificationsController::markAsRead/$1');
        $routes->put('notifications/mark-all-read', 'NotificationsController::markAllAsRead');
        $routes->delete('notifications/(:num)', 'NotificationsController::delete/$1');
        
        // Search & Bulk
        $routes->get('search/global', 'SearchController::global');
        $routes->post('search/advanced', 'SearchController::advanced');
        $routes->post('bulk/update-assets', 'BulkOperationsController::updateAssets');
        $routes->post('bulk/create-work-orders', 'BulkOperationsController::createWorkOrders');
        $routes->post('bulk/delete', 'BulkOperationsController::deleteMultiple');
        
        // Analytics
        $routes->get('analytics/kpis', 'AnalyticsController::kpis');
        $routes->get('analytics/assets/(:num)/kpis', 'AnalyticsController::getAssetKPIs/$1');
        $routes->get('analytics/departments', 'AnalyticsController::getDepartmentMetrics');
        $routes->get('analytics/department-metrics', 'AnalyticsController::getDepartmentMetrics');
        $routes->get('analytics/maintenance-costs', 'AnalyticsController::getMaintenanceCosts');
        $routes->get('analytics/downtime', 'AnalyticsController::getDowntimeAnalysis');
        
        // Reports
        $routes->post('reports/generate', 'ReportsController::generate');
        $routes->post('reports/schedule', 'ReportsController::schedule');
        $routes->get('reports/scheduled', 'ReportsController::getScheduled');
        
        // Audit
        $routes->get('audit-logs', 'AuditLogsController::index');
    });
    
    // ========================================================================
    // ASSET MODULE - Equipment, Machines, BOM, Hierarchy
    // ========================================================================
    $routes->group('', ['namespace' => 'App\Controllers\Api\V1\Modules\ASSET'], function($routes) {
        // Assets Unified
        $routes->get('assets-unified', 'AssetsUnifiedController::index');
        $routes->get('assets-unified/(:num)', 'AssetsUnifiedController::show/$1');
        $routes->post('assets-unified', 'AssetsUnifiedController::create');
        $routes->put('assets-unified/(:num)', 'AssetsUnifiedController::update/$1');
        $routes->delete('assets-unified/(:num)', 'AssetsUnifiedController::delete/$1');
        $routes->get('assets-unified/(:num)/hierarchy', 'AssetsUnifiedController::hierarchy/$1');
        
        // Equipment
        $routes->get('equipment', 'EamEquipmentController::index');
        $routes->get('equipment/(:num)', 'EamEquipmentController::show/$1');
        $routes->post('equipment', 'EamEquipmentController::create');
        $routes->put('equipment/(:num)', 'EamEquipmentController::update/$1');
        $routes->delete('equipment/(:num)', 'EamEquipmentController::delete/$1');
        $routes->get('equipment/(:num)/parts', 'EquipmentPartsController::getEquipmentParts/$1');
        
        // Machines
        $routes->get('machines', 'MachineController::index');
        $routes->get('machines/(:num)', 'MachineController::show/$1');
        $routes->post('machines', 'MachineController::create');
        $routes->put('machines/(:num)', 'MachineController::update/$1');
        $routes->delete('machines/(:num)', 'MachineController::delete/$1');
        
        // Assemblies
        $routes->get('assemblies', 'AssembliesController::index');
        $routes->get('assemblies/(:num)', 'AssembliesController::show/$1');
        $routes->post('assemblies', 'AssembliesController::create');
        $routes->put('assemblies/(:num)', 'AssembliesController::update/$1');
        $routes->delete('assemblies/(:num)', 'AssembliesController::delete/$1');
        $routes->get('assemblies/(:num)/parts', 'AssembliesController::parts/$1');
        
        // Parts
        $routes->get('parts', 'PartsController::index');
        $routes->get('parts/(:num)', 'PartsController::show/$1');
        $routes->post('parts', 'PartsController::create');
        $routes->put('parts/(:num)', 'PartsController::update/$1');
        $routes->delete('parts/(:num)', 'PartsController::delete/$1');
        $routes->get('parts/nested/(:num)', 'PartsController::getNestedParts/$1');
        $routes->get('parts/(:num)/history', 'EquipmentPartsController::getPartHistory/$1');
        
        // Facilities
        $routes->get('facilities', 'FacilitiesController::index');
        $routes->get('facilities/(:num)', 'FacilitiesController::show/$1');
        $routes->post('facilities', 'FacilitiesController::create');
        $routes->put('facilities/(:num)', 'FacilitiesController::update/$1');
        $routes->delete('facilities/(:num)', 'FacilitiesController::delete/$1');
        
        // Asset Tree & Hierarchy
        $routes->get('asset-tree/(:num)', 'AssetTreeController::getTree/$1');
        $routes->get('asset-node/(:num)', 'AssetTreeController::getNode/$1');
        $routes->post('asset-node', 'AssetTreeController::createNode');
        $routes->put('asset-node/(:num)', 'AssetTreeController::updateNode/$1');
        $routes->delete('asset-node/(:num)', 'AssetTreeController::deleteNode/$1');
        
        // BOM
        $routes->get('bom', 'BillOfMaterialsController::index');
        $routes->post('bom', 'BillOfMaterialsController::create');
        $routes->get('bom/(:num)', 'BillOfMaterialsController::show/$1');
        $routes->get('bom/(:num)/explode', 'BillOfMaterialsController::explode/$1');
        
        // 3D Models
        $routes->get('models/analytics/stats', 'ModelAnalyticsController::stats');
        $routes->get('models/analytics/recent-activity', 'ModelAnalyticsController::recentActivity');
        $routes->get('models/settings', 'ModelViewerController::getSettings');
        $routes->post('models/settings', 'ModelViewerController::updateSettings');
        
        // Hotspots
        $routes->get('hotspots', 'HotspotController::index');
        $routes->post('hotspots', 'HotspotController::create');
        $routes->put('hotspots/(:num)', 'HotspotController::update/$1');
        $routes->delete('hotspots/(:num)', 'HotspotController::delete/$1');
    });
    
    // ========================================================================
    // HRMS MODULE - Users, Departments, Shifts
    // ========================================================================
    $routes->group('', ['namespace' => 'App\Controllers\Api\V1\Modules\HRMS'], function($routes) {
        // Users
        $routes->get('users', 'UsersController::index');
        $routes->get('users/(:num)', 'UsersController::show/$1');
        $routes->post('users', 'UsersController::create');
        $routes->put('users/(:num)', 'UsersController::update/$1');
        $routes->delete('users/(:num)', 'UsersController::delete/$1');
        $routes->post('users/(:num)/assign-role', 'UsersController::assignRole/$1');
        
        // Skills
        $routes->get('skills', 'SkillsController::index');
        
        // Departments
        $routes->get('departments', 'DepartmentsController::index');
        $routes->get('departments/(:num)', 'DepartmentsController::show/$1');
        $routes->post('departments', 'DepartmentsController::create');
        $routes->put('departments/(:num)', 'DepartmentsController::update/$1');
